# Theme and Font
theme = TokyoNight
font-family = Hack Nerd Font
font-size = 12

# Disable ligatures to keep standard symbols
font-feature = -calt
font-feature = -liga
font-feature = -dlig

# Window and Tab management
keybind = alt+q=new_window
keybind = alt+w=new_tab
keybind = alt+e=close_surface

# F11 to toggle fullscreen
keybind = f11=toggle_fullscreen

# Don't show window dimensions
resize-overlay = never
