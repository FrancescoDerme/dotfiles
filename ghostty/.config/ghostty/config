# Theme
theme = TokyoNight

# Open a new terminal window
keybind = alt+q=new_window

# Open a new tab in the current window
keybind = alt+w=new_tab

# Close the current tab or window
keybind = alt+e=close_surface

# F11 to toggle fullscreen
keybind = f11=toggle_fullscreen

# Disable visual bell (makes the terminal flash when doing something invald)
bell-features = no-border,no-system
